# ══════════════════════════════════════════════════════════════════════════════
# Healthcare Migration — Variables d'environnement
# ══════════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS :
#   1. Copie ce fichier : Copy-Item ".env.example" ".env"
#   2. Remplis tes valeurs ci-dessous
#   3. Ne jamais committer le fichier .env sur GitHub !
# ══════════════════════════════════════════════════════════════════════════════

# ── MongoDB local (Docker) ──────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=CHANGE_MOI

# ── URI de connexion ────────────────────────────────────────────────────────
# MongoDB local (décommente si tu utilises MongoDB local) :
# MONGO_URI=mongodb://admin:CHANGE_MOI@mongo:27017/

# MongoDB Atlas (production — décommente et remplis) :
MONGO_URI=mongodb+srv://TON_USERNAME:TON_PASSWORD@TON_CLUSTER.mongodb.net/

# ── Base de données ─────────────────────────────────────────────────────────
DB_NAME=healthcare-dataset
COLL_NAME=healthcare-dataset

# ── Fichier source ──────────────────────────────────────────────────────────
DATA_FILE=/data/healthcare_dataset.json
BATCH_SIZE=500

# ── Mots de passe des rôles utilisateurs ────────────────────────────────────
# Choisis des mots de passe forts (min. 12 caractères, majuscules, chiffres, symboles)
READER_PASSWORD=CHANGE_MOI_READER
WRITER_PASSWORD=CHANGE_MOI_WRITER
DBADMIN_PASSWORD=CHANGE_MOI_ADMIN
